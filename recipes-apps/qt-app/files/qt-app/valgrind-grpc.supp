# ===========================================================================
# gRPC metadata std::variant<string_view, string> copy
# gRPC metadata values use std::variant; copying allocates a std::string heap
# buffer that may outlive the channel when the app exits during retry.
# ===========================================================================
{
   grpc_metadata_variant_string
   Memcheck:Leak
   match-leak-kinds: possible,reachable
   ...
   fun:*std*__detail*__variant*_Copy_ctor_base*
}
